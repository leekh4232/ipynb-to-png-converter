{
  "name": "notebook-to-png-converter",
  "displayName": "Jupyter Notebook to PNG Exporter",
  "description": "Convert Jupyter Notebook (.ipynb) files to PNG images",
  "version": "0.1.0",
  "publisher": "leekh",
  "repository": {
    "type": "git",
    "url": "https://github.com/leekh4232/ipynb-to-png-converter"
  },
  "author": {
    "name": "이광호",
    "email": "leekh4232@gmail.com"
  },
  "engines": {
    "vscode": "^1.84.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ipynb-to-png-converter.convertToPng",
        "title": "Convert Jupyter Notebook to PNG",
        "category": "Jupyter"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "ipynb-to-png-converter.convertToPng",
          "when": "resourceExtname == .ipynb",
          "group": "navigation@99"
        }
      ],
      "editor/title/context": [
        {
          "command": "ipynb-to-png-converter.convertToPng",
          "when": "resourceExtname == .ipynb",
          "group": "navigation@99"
        }
      ],
      "commandPalette": [
        {
          "command": "ipynb-to-png-converter.convertToPng",
          "when": "resourceExtname == .ipynb || activeEditor == 'workbench.editor.notebook'"
        }
      ]
    },
    "configuration": {
      "title": "Jupyter to PNG Converter",
      "properties": {
        "ipynb-to-png-converter.deviceScaleFactor": {
          "type": "number",
          "default": 3,
          "minimum": 1,
          "maximum": 5,
          "description": "Device scale factor for PNG image resolution (1-5). Higher values produce higher resolution images."
        },
        "ipynb-to-png-converter.imageWidth": {
          "type": "number",
          "default": 1024,
          "minimum": 480,
          "maximum": 2400,
          "description": "Width of the generated PNG image in CSS pixels (final PNG width = imageWidth × deviceScaleFactor)."
        },
        "ipynb-to-png-converter.codeTheme": {
          "type": "string",
          "default": "dracula",
          "enum": [
            "dracula",
            "github",
            "github-dark",
            "atom-one-light",
            "atom-one-dark",
            "monokai",
            "nord",
            "vs2015"
          ],
          "enumDescriptions": [
            "Dracula",
            "GitHub Light",
            "GitHub Dark",
            "Atom One Light",
            "Atom One Dark",
            "Monokai",
            "Nord",
            "Visual Studio Dark"
          ],
          "description": "Syntax highlighting theme for source code cells."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run vendor && npm run compile",
    "vendor": "mkdir -p media/themes && cp node_modules/html2canvas/dist/html2canvas.min.js media/html2canvas.min.js && cp node_modules/highlight.js/styles/{github,github-dark,atom-one-light,atom-one-dark,monokai,nord,vs2015}.css media/themes/ && cp node_modules/highlight.js/styles/base16/dracula.css media/themes/dracula.css && cp node_modules/github-markdown-css/github-markdown-light.css media/github-markdown.css",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "^20.4.2",
    "@types/vscode": "^1.84.0",
    "@typescript-eslint/eslint-plugin": "^6.2.1",
    "@typescript-eslint/parser": "^6.2.1",
    "@vscode/test-electron": "^2.3.3",
    "eslint": "^8.45.0",
    "github-markdown-css": "^5.9.0",
    "glob": "^10.3.3",
    "html2canvas": "^1.4.1",
    "mocha": "^10.2.0",
    "typescript": "^5.1.6"
  },
  "dependencies": {
    "highlight.js": "^11.9.0",
    "marked": "^12.0.0"
  }
}
